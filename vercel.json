{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "server/server-dev.js",
      "use": "@vercel/node"
    },
    {
      "src": "ai-service/app-simple.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server-dev.js"
    },
    {
      "src": "/ai/(.*)",
      "dest": "ai-service/app-simple.py"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ]
}
